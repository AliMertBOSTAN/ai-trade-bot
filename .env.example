# ============================================================
#  AI Trade Bot - Ortam Değişkenleri
#  Bu dosyayı ".env" olarak kopyalayın ve değerleri doldurun.
#  .env dosyasını ASLA git'e commit etmeyin.
# ============================================================

# --- RPC Endpoint'leri (kendi Alchemy/Infura/QuickNode URL'lerinizi girin) ---
RPC_ETHEREUM=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
RPC_ARBITRUM=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
RPC_BASE=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
RPC_OPTIMISM=https://opt-mainnet.g.alchemy.com/v2/YOUR_KEY
RPC_BSC=https://bsc-dataseed.binance.org
RPC_POLYGON=https://polygon-rpc.com

# --- AI / LLM sağlayıcı ---
# Hem hibrit sinyalin LLM katmanı HEM de piyasa analisti (/analyst,
# CEX/DEX + haber karşılaştırma yorumu) bu key'i kullanır.
# Sağlayıcı: "deepseek" | "anthropic" | "openai" | "none"
LLM_PROVIDER=deepseek

# DeepSeek (varsayılan, OpenAI uyumlu API)
# Anahtarı https://platform.deepseek.com adresinden alın.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Anlık haber akışları (opsiyonel) ---
# Boş bırakılırsa varsayılanlar kullanılır:
# CoinDesk, Cointelegraph, Decrypt, The Defiant. Virgülle ayrılmış RSS URL'leri.
NEWS_FEEDS=

# --- Cüzdan (YALNIZCA gerçek işlem modu için; paper modda gerekmez) ---
# UYARI: Burası gerçek para. Asla ana cüzdanınızın anahtarını kullanmayın.
# Boş bırakırsanız bot yalnızca paper (simülasyon) modunda çalışır.
WALLET_PRIVATE_KEY=

# --- Çalışma modu: "paper" | "live" ---
TRADING_MODE=paper

# --- Engine otomatik başlatma (Electron) ---
# Electron, Python engine'ini uygulamayla birlikte otomatik başlatır/durdurur.
# Kapatmak için 0 yapın (engine'i elle "uvicorn engine.app:app --port 8787"
# ile başlatırsınız). Özel Python yorumlayıcı yolu için ENGINE_PYTHON kullanın.
AUTO_START_ENGINE=1
# ENGINE_PYTHON=C:\path\to\python.exe
