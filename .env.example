# ============================================================
#  AI Trade Bot - Ortam Değişkenleri
#  Bu dosyayı ".env" olarak kopyalayın ve değerleri doldurun.
#  .env dosyasını ASLA git'e commit etmeyin.
# ============================================================

# --- RPC Endpoint'leri (kendi Alchemy/Infura/QuickNode URL'lerinizi girin) ---
RPC_ETHEREUM=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
RPC_ARBITRUM=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
RPC_BASE=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
RPC_OPTIMISM=https://opt-mainnet.g.alchemy.com/v2/YOUR_KEY
RPC_BSC=https://bsc-dataseed.binance.org
RPC_POLYGON=https://polygon-rpc.com

# --- AI / LLM sağlayıcı ---
# Hem hibrit sinyalin LLM katmanı HEM de piyasa analisti (/analyst,
# CEX/DEX + haber karşılaştırma yorumu) bu key'i kullanır.
# Sağlayıcı: "deepseek" | "anthropic" | "openai" | "none"
LLM_PROVIDER=deepseek

# DeepSeek (varsayılan, OpenAI uyumlu API)
# Anahtarı https://platform.deepseek.com adresinden alın.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- Anthropic-uyumlu sağlayıcı (Claude SDK'sı ile aynı format) ---
# ANTHROPIC_BASE_URL boşsa GERÇEK Claude'a gider.
# DeepSeek'i Anthropic formatında çağırmak için (deepseek-v4-pro) şu 4 satırı kullan:
#   LLM_PROVIDER=anthropic
#   ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
#   ANTHROPIC_API_KEY=<DeepSeek anahtarın>
#   ANTHROPIC_MODEL=deepseek-v4-pro      (hızlı/ucuz için: deepseek-v4-flash)
# İleride gerçek Claude'a geçmek için: ANTHROPIC_BASE_URL'i boşalt,
#   ANTHROPIC_API_KEY'i Claude anahtarınla değiştir, ANTHROPIC_MODEL=claude-opus-4-...
ANTHROPIC_BASE_URL=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=deepseek-v4-pro

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Anlık haber akışları (opsiyonel) ---
# Boş bırakılırsa varsayılanlar kullanılır:
# CoinDesk, Cointelegraph, Decrypt, The Defiant. Virgülle ayrılmış RSS URL'leri.
NEWS_FEEDS=

# --- Cüzdan (YALNIZCA gerçek işlem modu için; paper modda gerekmez) ---
# UYARI: Burası gerçek para. Asla ana cüzdanınızın anahtarını kullanmayın.
# Boş bırakırsanız bot yalnızca paper (simülasyon) modunda çalışır.
WALLET_PRIVATE_KEY=

# --- CEX (Binance spot) — GELECEK İÇİN, şu an opsiyonel ---
# Boş bırakılırsa Binance yalnızca VERİ için kullanılır (fiyat/karşılaştırma);
# hiçbir CEX emri gönderilmez. Trade izinli key+secret girilirse CexBroker
# (zincir-dışı, gas yok) devreye alınabilir. Test için:
#   BINANCE_BASE=https://testnet.binance.vision
BINANCE_API_KEY=
BINANCE_SECRET=
# BINANCE_BASE=https://api.binance.com

# --- Çalışma modu: "paper" | "live" ---
TRADING_MODE=paper

# --- Engine otomatik başlatma (Electron) ---
# Electron, Python engine'ini uygulamayla birlikte otomatik başlatır/durdurur.
# Kapatmak için 0 yapın (engine'i elle "uvicorn engine.app:app --port 8787"
# ile başlatırsınız). Özel Python yorumlayıcı yolu için ENGINE_PYTHON kullanın.
AUTO_START_ENGINE=1
# ENGINE_PYTHON=C:\path\to\python.exe

# ---------------------------------------------------------------------------
# execd — Rust emir-iletim servisi (ADR-0001). UYARI: WALLET_KEY YALNIZ execd'de.
# ---------------------------------------------------------------------------
EXEC_BACKEND=python          # python (varsayılan) | rust
EXECD_URL=http://127.0.0.1:8788
EXECD_PORT=8788
EXECD_MODE=paper             # paper | live  (live'a bilinçli geçin)
MAX_GAS_GWEI=150
# WALLET_KEY=0x...           # SADECE execd ortamı; Python motoru bunu GÖRMEMELİ
# FLASHBOTS_SIGNER_KEY=0x... # bundle kimlik anahtarı (cüzdandan ayrı)
# HYPERLIQUID_KEY=0x...      # perp imzalama
# EXECD_SHARED_SECRET=...    # yerel çağrı doğrulama header'ı (opsiyonel)

# ---------------------------------------------------------------------------
# Risk / işlem ayarı (kod düzenlemeden .env'den ayarla)
# ---------------------------------------------------------------------------
MIN_CONFIDENCE=0.73          # işlem açma eşiği (0..1). Düşür -> daha çok işlem
MAX_POSITION_USD=500         # tek pozisyonda azami $
MAX_OPEN_POSITIONS=5
MAX_GAS_GWEI=80
